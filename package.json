{
  "name": "ai-workspace-v2",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "ai-workspace-v2": "./bin/start.ts"
  },
  "scripts": {
    "dev": "bun --bun bin/start.ts --dev",
    "dev:hot": "bun --bun bin/start.ts --hot",
    "build": "bun --bun next build",
    "start": "bun --bun bin/start.ts",
    "lint": "bun --bun tsc --noEmit && bun --bun eslint src/",
    "test": "bun --bun vitest run",
    "test:watch": "bun --bun vitest",
    "next-server": "bun run bin/next-server.ts",
    "chat-server": "bun run bin/chat-server.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "yaml": "^2.8.3",
    "zod": "3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.1",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
